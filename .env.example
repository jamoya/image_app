# n8n webhook the frontend POSTs images to.
# In dev, the frontend calls VITE_N8N_PROXY_PATH + /webhook/<id>; Vite forwards
# that prefix to VITE_N8N_TARGET (see vite.config.js). Same-origin sidesteps
# n8n's missing CORS headers.
VITE_N8N_TARGET=http://localhost:5678
VITE_N8N_PROXY_PATH=/n8n
VITE_N8N_WEBHOOK_ID=replace-with-your-webhook-uuid
